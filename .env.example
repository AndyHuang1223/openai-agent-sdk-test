OPENAI_API_KEY=your_openai_api_key_here
MS_LEARN_MCP_URL=https://learn.microsoft.com/api/mcp
CHAT_CONFIG_PATH=./config/chat.json
CHAT_SERVICE_NAME=openai-agent-sdk-test
CHAT_MODEL_GENERAL=gpt-4.1-mini
CHAT_MODEL_CSHARP=gpt-4.1-mini
CHAT_MODEL_CSHARP_FALLBACK=gpt-4.1-mini
CHAT_ROUTING_ENABLE_CSHARP_ROUTE=true
CHAT_ROUTING_CSHARP_ONLY_USES_MCP=true
